# =====================================================
# GriotKnowledge — Configuration Template
# =====================================================
# COPIEZ ce fichier vers .env et remplissez avec vos vraies valeurs
# NE COMMITEZ JAMAIS le fichier .env avec vos secrets !

# === QDRANT ===
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=griot_corpus

# === MODÈLE D'EMBEDDING ===
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIMENSION=384

# === LLM (OpenRouter) ===
# Obtenez votre clé sur : https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here
LLM_MODEL=stepfun/step-3.5-flash:free

# Modèles gratuits alternatifs :
# - qwen/qwen-2-7b-instruct:free
# - meta-llama/llama-3-8b-instruct:free
# - google/gemini-flash-1.5:free

# === API ===
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# === SÉCURITÉ (Production) ===
# Générez une clé secrète forte : python -c "import secrets; print(secrets.token_urlsafe(32))"
API_SECRET_KEY=changez-cette-cle-secrete-en-production

# CORS - Limitez aux domaines autorisés en production
CORS_ORIGINS=http://localhost:3000,https://votre-domaine.com

# Rate Limiting
RATE_LIMIT=100/minute

# === CORPUS ===
CORPUS_PATH=./data/corpus

# === LOGS ===
LOG_LEVEL=INFO
LOG_FORMAT=json
